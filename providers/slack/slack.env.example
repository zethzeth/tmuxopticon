# slack-alarm-watch — config + secrets
# Copy this to ~/.config/tmuxopticon/slack.env and fill in real values.
# Kept out of the repo (it holds a token), alongside ~/.config/tmuxopticon/uptimerobot.key.
#   mkdir -p ~/.config/tmuxopticon
#   cp slack.env.example ~/.config/tmuxopticon/slack.env && $EDITOR ~/.config/tmuxopticon/slack.env
# With no such file, slack-alarm-watch.sh is a quiet no-op.

# User OAuth token (xoxp-…) from your internal Slack app. See
# guides/slack-alarm-watch.md for how a non-admin member creates the app and
# gets this token. Treat it like a password.
SLACK_TOKEN=

# Channels to watch, space-separated. Each is a channel ID, optionally with a
# short display label after a colon: "C0ABC123:prod-alerts C0DEF456:db".
# Get a channel's ID in Slack: open the channel → click its name → the ID is at
# the bottom of the About tab (starts with C). You must be a member of each.
SLACK_ALARM_CHANNELS=

# Optional overrides (sensible defaults shown):
# SLACK_ALARM_TTL=86400          # seconds an alarm stays "active" before auto-expiring
# SLACK_ALARM_MAX=50             # cap on stored active alarms
# SLACK_ALARM_IGNORE=~/.config/tmuxopticon/slack-alarm-ignore.txt   # false-alarm regex filter
# SLACK_ALARM_CACHE=/tmp/tmuxopticon.alarms.$UID                    # cache the sidebar reads
